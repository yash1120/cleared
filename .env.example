# Copy to .env and fill in. The Anthropic SDK reads ANTHROPIC_API_KEY automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Model split (matches the project plan): cheap+strong for generation, strongest for the eval judge.
CLEARED_GEN_MODEL=claude-sonnet-4-6
CLEARED_JUDGE_MODEL=claude-opus-4-7

# Offline mode: 1/true forces canned + heuristic output with no API calls.
# If unset, mock turns on automatically whenever no API key is present. Set to 0 to force live mode.
# CLEARED_MOCK=1

# Auth — set a long random value in production (JWTs are signed with this).
CLEARED_SECRET_KEY=change-me-to-a-long-random-string

# Database file location (default: cleared/data/cleared.db).
# CLEARED_DB_PATH=/data/cleared.db

# Real sanctions/PEP screening (optional): OpenSanctions hosted API or self-hosted yente.
# CLEARED_OPENSANCTIONS_URL=https://api.opensanctions.org
# CLEARED_OPENSANCTIONS_KEY=
